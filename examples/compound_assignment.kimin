// Compound assignment operators: +=, -=, *=, /=

let mut x = 10
x += 5
print(x)   // 15

x -= 3
print(x)   // 12

x *= 2
print(x)   // 24

x /= 4
print(x)   // 6

// Works inside blocks and functions
let mut counter = 0
{
    counter += 1
    counter += 1
    counter += 1
}
print(counter)   // 3

fn add_to(start: Number, amount: Number) -> Number {
    let mut result = start
    result += amount
    return result
}
print(add_to(10, 7))   // 17
