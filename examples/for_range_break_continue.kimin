// Skip 3, print 0 1 2 4
for i in range(0, 5) {
    if i == 3 {
        continue
    }
    print(i)
}

// Break at 7: prints 5 6
for i in range(5, 10) {
    if i == 7 {
        break
    }
    print(i)
}

// Continue in nested loops (only affects innermost)
for x in range(0, 3) {
    for y in range(0, 3) {
        if y == 1 {
            continue
        }
        print(x * 10 + y)
    }
}
