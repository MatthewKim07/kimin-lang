// Demonstrates typed function parameters and return types.

fn greet(name: Text) -> Text {
  return "Hello, " + name
}

fn add(a: Number, b: Number) -> Number {
  return a + b
}

fn is_positive(x: Number) -> Bool {
  return x > 0
}

print(greet("world"))
print(add(3, 4))
print(is_positive(5))
print(is_positive(-1))

// Functions without return annotation return Unknown (gradual typing).
fn no_ret(x: Number) {
  print(x)
}

no_ret(99)
